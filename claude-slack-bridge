#!/usr/bin/env bash
set -euo pipefail

REAL_SCRIPT="$(readlink -f "$0" 2>/dev/null || readlink "$0" 2>/dev/null || echo "$0")"
BRIDGE_DIR="$(cd "$(dirname "$REAL_SCRIPT")" && pwd)"
PID_FILE="$BRIDGE_DIR/bridge.pid"

TMUX_SESSION="${TMUX_SESSION:-claude}"

case "${1:-help}" in
  start)
    # Start daemon
    "$BRIDGE_DIR/start-bridge.sh"
    # Drop into tmux session
    if tmux has-session -t "$TMUX_SESSION" 2>/dev/null; then
      tmux attach -t "$TMUX_SESSION"
    else
      tmux new-session -s "$TMUX_SESSION"
    fi
    ;;
  stop)
    # Kill tmux session
    if tmux has-session -t "$TMUX_SESSION" 2>/dev/null; then
      tmux kill-session -t "$TMUX_SESSION"
      echo "tmux session '$TMUX_SESSION' killed."
    else
      echo "No tmux session '$TMUX_SESSION'."
    fi
    # Kill daemon — try PID file first, then hunt for the process
    KILLED=false
    if [ -f "$PID_FILE" ] && kill -0 "$(cat "$PID_FILE")" 2>/dev/null; then
      kill "$(cat "$PID_FILE")"
      KILLED=true
    fi
    rm -f "$PID_FILE"
    # Catch any orphaned daemon process
    ORPHAN=$(pgrep -f "node.*claude-slack-bridge.*daemon.js" 2>/dev/null || true)
    if [ -n "$ORPHAN" ]; then
      kill $ORPHAN 2>/dev/null || true
      KILLED=true
    fi
    if [ "$KILLED" = true ]; then
      echo "Daemon stopped."
    else
      echo "Daemon not running."
    fi
    ;;
  restart)
    "$0" stop
    sleep 1
    "$0" start
    ;;
status)
    # Daemon
    if [ -f "$PID_FILE" ] && kill -0 "$(cat "$PID_FILE")" 2>/dev/null; then
      echo "Daemon:  running (PID $(cat "$PID_FILE"))"
    else
      echo "Daemon:  stopped"
    fi
    # Health
    if curl -s http://127.0.0.1:${BRIDGE_PORT:-3271}/health > /dev/null 2>&1; then
      echo "API:     healthy"
    else
      echo "API:     unreachable"
    fi
    # tmux
    if tmux has-session -t "$TMUX_SESSION" 2>/dev/null; then
      echo "Claude:  running in tmux '$TMUX_SESSION'"
    else
      echo "Claude:  not running"
    fi
    ;;
  log|logs)
    tail -f "$BRIDGE_DIR/bridge.log"
    ;;
  *)
    echo "Usage: claude-slack-bridge {start|stop|restart|status|logs}"
    ;;
esac
